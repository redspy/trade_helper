# LLM 백엔드: auto(기본) | api | claude_cli
#  - claude_cli: Claude Code 헤드리스 모드(`claude -p`) — API 키 불필요 (로그인 구독 사용)
#  - api:        Anthropic SDK — ANTHROPIC_API_KEY 필요
#  - auto:       API 키가 있으면 api, 없으면 claude_cli
LLM_BACKEND=auto

# api 백엔드용 (claude_cli만 쓰면 비워둬도 됨)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# claude_cli 백엔드 모델 오버라이드 (비우면 CLI 기본 모델)
CLAUDE_CLI_MODEL=

# Database
# SQLite (기본값): sqlite:///data/trade_dash.db
# PostgreSQL:      postgresql+psycopg://user:password@host:5432/trade_dash
DATABASE_URL=sqlite:///data/trade_dash.db

# 뉴스 헤드라인 최대 수집 개수 (티커당)
MAX_NEWS_PER_TICKER=5
